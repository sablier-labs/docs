{
  "name": "@sablier/docs",
  "description": "Documentation and guides for Sablier",
  "author": {
    "name": "Sablier Labs Ltd",
    "url": "https://sablier.com"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "bugs": {
    "url": "https://github.com/sablier-labs/docs/issues"
  },
  "dependencies": {
    "@algolia/client-search": "^4.23.3",
    "@docusaurus/core": "^3.7.0",
    "@docusaurus/plugin-client-redirects": "^3.7.0",
    "@docusaurus/plugin-vercel-analytics": "^3.7.0",
    "@docusaurus/preset-classic": "^3.7.0",
    "@docusaurus/theme-classic": "^3.7.0",
    "@docusaurus/theme-mermaid": "^3.7.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "~3.1.0",
    "@sablier/deployments": "1.0.0-alpha.25",
    "@vercel/analytics": "^1.5.0",
    "axios": "^1.8.4",
    "clsx": "^2.1.1",
    "docusaurus-plugin-remote-content": "^4.0.0",
    "docusaurus-theme-github-codeblock": "^2.0.2",
    "function-plot": "^1.25.1",
    "hast-util-is-element": "3.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "18.2",
    "react-dom": "18.2",
    "react-loadable": "^5.5.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "7",
    "remark-math": "6"
  },
  "devDependencies": {
    "@docusaurus/eslint-plugin": "^3.7.0",
    "@docusaurus/module-type-aliases": "^3.7.0",
    "@docusaurus/tsconfig": "^3.7.0",
    "@docusaurus/types": "^3.7.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^8.57",
    "eslint-plugin-mdx": "^3.4.1",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "typescript": "^5.4.5",
    "vercel": "^41.6.2"
  },
  "engines": {
    "node": ">=20.0"
  },
  "homepage": "https://docs.sablier.com",
  "keywords": [
    "asset-streaming",
    "blockchain",
    "cryptotokens",
    "cryptoassets",
    "ethereum",
    "money-streaming",
    "real-time-finance",
    "sablier",
    "sablier-flow",
    "sablier-lockup",
    "smart-contracts",
    "solidity",
    "token-streaming",
    "token-vesting"
  ],
  "private": true,
  "repository": "github:sablier-labs/docs",
  "resolutions": {
    "jackspeak": "2.1.1"
  },
  "scripts": {
    "autogen": "bun run scripts/autogen/index.ts",
    "autogen:deployments": "bun run scripts/autogen/deployments.ts",
    "autogen:indexers": "bun run scripts/autogen/indexers.ts",
    "autogen:reference": "bash scripts/autogen-references.sh",
    "build": "bun run autogen --override --verbose && docusaurus build",
    "check": "bun run typecheck && bun run prettier:check && bun run eslint:check",
    "clean": "docusaurus clear && rm -rf ./src/autogen/**/*.mdx",
    "deploy": "docusaurus deploy",
    "eslint:check": "bun eslint --cache . --ext md,mdx,ts,tsx",
    "eslint:fix": "bun eslint --cache --fix . --ext md,mdx,ts,tsx",
    "fix": "bun run prettier:write && bun run eslint:fix",
    "prepare": "husky",
    "prettier:check": "prettier --cache --check \"**/*.{json,md,mdx,ts,tsx,yml}\"",
    "prettier:write": "prettier --cache --write \"**/*.{json,md,mdx,ts,tsx,yml}\"",
    "serve": "docusaurus serve",
    "start": "bun run autogen && docusaurus start",
    "swizzle": "docusaurus swizzle",
    "typecheck": "tsc --noEmit"
  }
}
